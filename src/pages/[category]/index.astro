---
import ListingPage from '../../layouts/page-types/ListingPage.astro';
import { SITE } from '../../data/site';
import posts from '../../data/posts.json';

const categoryMeta: Record<string, { name: string; description: string; intro: string; heroImage: string; heroImageAlt: string }> = {
  espresso: {
    name: 'Espresso Machines & Gear',
    description: 'Espresso machine buying guides, dial-in workflows, and grinder settings for home baristas.',
    intro: 'Budget espresso machines, shot dial-in technique, and grinder calibration guides to help you pull better shots at home.',
    heroImage: '/assets/hero-espresso.webp',
    heroImageAlt: 'Bottomless portafilter pulling espresso into a ceramic cup with golden crema',
  },
  grinders: {
    name: 'Coffee Grinders',
    description: 'Coffee grinder buying guides for pour over, French press, espresso, and everyday brewing.',
    intro: 'Hand grinders, electric burr grinders, and maintenance guides to help you find the right grinder for your brew method and budget.',
    heroImage: '/assets/hero-grinders.webp',
    heroImageAlt: 'Still life of manual and electric coffee grinders with various grind sizes in ceramic bowls',
  },
  brewers: {
    name: 'Coffee Makers & Brewers',
    description: 'Coffee maker buying guides and brewer comparisons for drip, pour over, and grind-and-brew machines.',
    intro: 'Drip coffee makers, grind-and-brew machines, pour over drippers, and head-to-head brewer comparisons to match your daily workflow.',
    heroImage: '/assets/hero-brewers.webp',
    heroImageAlt: 'Chemex, V60 dripper, and French press arranged with freshly brewed coffee',
  },
  accessories: {
    name: 'Brewing Accessories',
    description: 'Coffee scale, kettle, and accessory guides for pour over and espresso brewing.',
    intro: 'Scales, gooseneck kettles, and other accessories that improve consistency and control across brew methods.',
    heroImage: '/assets/hero-all-guides.webp',
    heroImageAlt: 'Curated flat lay of coffee brewing accessories and gear',
  },
  education: {
    name: 'Brew Education',
    description: 'Coffee brewing guides covering ratios, techniques, and practical tips for better cups at home.',
    intro: 'Practical brewing knowledge — ratios, techniques, and reference guides to level up your daily cup.',
    heroImage: '/assets/hero-all-guides.webp',
    heroImageAlt: 'Curated flat lay of coffee gear representing the range of home brewing methods',
  },
};

export function getStaticPaths() {
  const categories = [...new Set(posts.map((p) => p.category))];
  return categories.map((cat) => ({
    params: { category: cat },
    props: {
      category: cat,
      categoryPosts: posts
        .filter((p) => p.category === cat)
        .sort((a, b) => b.dateModified.localeCompare(a.dateModified)),
    },
  }));
}

const { category, categoryPosts } = Astro.props;
const meta = categoryMeta[category] || {
  name: category,
  description: '',
  intro: '',
  heroImage: '/assets/hero-all-guides.webp',
  heroImageAlt: 'Coffee gear',
};
---
<ListingPage
  title={meta.name}
  seoTitle={`${meta.name} | ${SITE.name}`}
  description={meta.description}
  intro={meta.intro}
  canonical={`${SITE.url}/${category}/`}
  heroImage={meta.heroImage}
  heroImageAlt={meta.heroImageAlt}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: meta.name },
  ]}
  posts={categoryPosts}
/>
