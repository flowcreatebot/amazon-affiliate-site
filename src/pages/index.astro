---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Toc from '../components/Toc.astro';
import PostListing from '../components/PostListing.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { SITE } from '../data/site';
import posts from '../data/posts.json';

const title = 'Coffee Gear Lab: Honest Buyer Guides for Home Brewers';
const description = 'High-intent coffee gear guides and comparisons for home brewers: best grinders, affordable espresso machines, and brew method matchups.';
const canonical = `${SITE.url}/`;

const moneyPosts = posts
  .filter((p) => p.pageType === 'money')
  .sort((a, b) => b.dateModified.localeCompare(a.dateModified));

const supportPosts = posts
  .filter((p) => p.pageType !== 'money')
  .sort((a, b) => b.dateModified.localeCompare(a.dateModified));
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogTitle="Coffee Gear Lab"
  ogDescription="High-intent coffee gear buying guides for beginners and enthusiasts."
  ogType="website"
  ogUrl={canonical}
>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Start here' },
  ]} />

  <h1>Coffee Gear Guides That Help You Buy Faster</h1>
  <p class="lead">No generic fluff. Just practical picks, clear trade-offs, and quick links to deeper guides so you can choose the right gear and start brewing.</p>

  <Toc
    items={[
      { href: '#high-intent-guides', label: 'Start with high-intent guides' },
      { href: '#supporting-education', label: 'Supporting brew education' },
    ]}
    ordered={false}
  />

  <section id="high-intent-guides">
    <h2>Start with high-intent guides</h2>
    <PostListing posts={moneyPosts} initialCount={8} />
  </section>

  <section id="supporting-education">
    <h2>Supporting brew education</h2>
    <PostListing posts={supportPosts} />
  </section>

  <p><a href="/posts/">Browse all coffee guides &rarr;</a></p>

  <AffiliateDisclosure text="Some links may earn a commission at no extra cost to you. We only recommend gear that provides clear value for specific use cases." />
</BaseLayout>
