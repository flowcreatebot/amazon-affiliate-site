import { getResolvedProducts, amazonUrl } from '../../data/products';

const slug = 'best-hand-grinder-for-espresso-under-100';
const title = 'Best Hand Grinder for Espresso Under 100 (2026): 5 Picks';
const description =
  'Shopping for the best hand grinder for espresso under 100? Here are 5 researched picks under $100, with honest trade-offs and a simple buying guide for 2026.';

const productsRaw = getResolvedProducts(slug);

const resolvedProductImages: Record<string, string> = {
  B0CY1XFXB8: 'https://m.media-amazon.com/images/I/71JlAmQq2hL._AC_SL500_.jpg',
  B0CJ4YFMQ9: 'https://m.media-amazon.com/images/I/611nhLRKWfL._AC_SL500_.jpg',
  B0833SDN8M: 'https://m.media-amazon.com/images/I/61Y8BsO8kYL._AC_SL500_.jpg',
  B0CCYBVQ9B: 'https://m.media-amazon.com/images/I/612GGkJub7L._AC_SL500_.jpg',
  B013R3Q7B2: 'https://m.media-amazon.com/images/I/71-9Q-pmKyL._AC_SL500_.jpg',
};

const products = productsRaw.map((p) => ({
  ...p,
  image: resolvedProductImages[p.asin] ?? p.image,
}));
