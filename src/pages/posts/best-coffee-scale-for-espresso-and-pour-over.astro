import { getResolvedProducts, amazonUrl } from '../../data/products';

const slug = 'best-coffee-scale-for-espresso-and-pour-over';
const title = 'Best Coffee Scale for Espresso and Pour Over (2026)';
const description = 'We compared the best coffee scale for espresso and pour over in 2026 by speed, footprint, and workflow so you can buy the right fit and brew more consistently.';
const canonical = `${SITE.url}/posts/${slug}.html`;

const products = getResolvedProducts('best-coffee-scale-for-espresso-and-pour-over');

const faqs = [
  {
    q: 'Do I need a different scale for espresso and pour over?',
    a: 'Not always. One scale can handle both if it has quick response, a stable timer, and a footprint that fits your espresso setup. Espresso-first users should prioritize response speed; pour-over-first users should prioritize readability and timer ergonomics.',
  },
  {
    q: 'What is the ideal precision for coffee scales?',
    a: 'For home coffee brewing, 0.1 g readability is the practical standard. It gives enough precision for espresso yield tracking and pour over ratio control without forcing you into expensive lab-style equipment.',
  },
  {
    q: 'Is app connectivity worth paying extra for?',
    a: 'It depends on your routine. App-connected scales are useful if you log recipes, track consistency, or run repeatable brew profiles. If you just want reliable daily brewing, a simpler non-app model is usually enough.',
  },
  {
    q: 'How often should I calibrate a coffee scale?',
    a: 'For normal home use, check accuracy every few months or whenever readings seem inconsistent. Keep the scale dry, avoid loading heavy objects on it, and use a known calibration weight if your model supports calibration mode.',
  },
  {
    q: 'Why does scale response speed matter so much for espresso?',
    a: 'Espresso output changes quickly in the final seconds of a shot. If the display lags, you stop late and overshoot your target yield. Faster response gives tighter control and more repeatable flavor.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    blogPosting({
      headline: title,
      description,
      slug,
      datePublished: '2026-03-11',
      dateModified: '2026-03-11',
      image: products[0].image,
    }),
    {
      '@type': 'ItemList',
      name: 'Best coffee scale for espresso and pour over picks',
      itemListOrder: 'https://schema.org/ItemListOrderAscending',
      numberOfItems: products.length,
      author: publisher,
      itemListElement: products.map((product, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: product.name,
        url: amazonUrl(product.asin),
      })),
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.a,
        },
      })),
    },
  ],
};
