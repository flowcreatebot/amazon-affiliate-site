        cons={[
          'Smaller brew volume than a home setup',
          'Less room for fussy experiments and larger doses',
        ]}
      />
      <p><CtaButton href={amazonUrl(products[2].asin)} external>Check Price on Amazon</CtaButton></p>
    </section>
