      { category: 'Clarity', tagline: 'Best for cleaner, lighter cups', icon: 'volume-x', color: '#5C3D2E', features: ['Flat burr flavor separation', 'Low static workflow', 'Great for lighter roasts', 'Filter-focused design'], topPick: 'Fellow Ode Gen 2', price: '$$$', subtitle: 'Cleanest cup profile', asin: 'B0BLRMCM9Y' },
