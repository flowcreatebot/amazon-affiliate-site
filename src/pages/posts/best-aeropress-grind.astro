  }}
  products={products}
  heroPicks={{
    title: '8 AeroPress-Friendly Grinders Worth Buying in 2026',
    subtitle: 'Start at medium-fine, then pick the grinder that makes that sweet spot easy to repeat',
    picks: [
      { category: 'Overall', tagline: 'Best all-around fit for most kitchens', icon: 'target', color: '#2C1810', features: ['Easy to dial for medium-fine', 'Covers AeroPress to espresso', 'Good long-term support', 'Strong everyday value'], topPick: 'Baratza Encore ESP', price: '$$', subtitle: 'The easiest smart buy', asin: 'B0BW272XCV' },
