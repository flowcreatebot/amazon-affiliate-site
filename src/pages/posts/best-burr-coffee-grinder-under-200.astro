    price={products[0].price}
    ctaUrl={amazonUrl(products[0].asin)}
  />
  <p><strong>Best for:</strong> Home brewers who want one grinder for pour over, drip, and occasional espresso without crossing the $200 threshold.</p>
  <ProsCons
    pros={[
      'Consistent grind quality for this price class.',
      'Useful espresso-focused adjustment zone.',
      'Strong long-term serviceability and parts support.',
