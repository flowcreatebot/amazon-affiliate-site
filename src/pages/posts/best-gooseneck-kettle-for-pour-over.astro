    <h3>4) COSORI Electric Gooseneck Kettle (ASIN: B07G2MBM6L)</h3>
    <ProductCard
      title="COSORI Electric Gooseneck Kettle"
      image={{ src: 'https://m.media-amazon.com/images/I/61loaANnLDL._AC_SL500_.jpg', alt: 'COSORI electric gooseneck kettle for pour over coffee', width: 500, height: 500 }}
      badge={{ label: 'Best for Beginners', variant: 'beginners' }}
      rating={{ score: 4.5 }}
