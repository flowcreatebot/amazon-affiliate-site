  <section id="comparison">
    <ComparisonTable
      timestamp="Prices updated: March 10, 2026"
      headers={['Product', 'Best For', 'Type', 'Capacity', '']}
      ariaLabel="Best gooseneck kettle for pour over comparison"
    >
