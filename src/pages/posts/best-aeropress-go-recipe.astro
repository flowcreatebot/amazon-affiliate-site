        { name: 'MiiCoffee Nano Coffee Scale with Timer', desc: 'Tiny enough to pack, useful enough to stop your ratio from drifting all over the place.', asin: 'B0CGMHTWM2' },
        { name: 'AeroPress Paper Micro-Filters', desc: 'The simple default if you like a cleaner cup with less sediment.', asin: 'B005UPSLX8' },
