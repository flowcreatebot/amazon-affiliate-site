          { label: 'Stronger mug', icon: 'target', points: ['Brew concentrate then add bypass water', 'Best for milk drinks or punchier cups', 'Measure the bypass if you want repeatable results'], badge: 'Most flexible' },
          { label: 'Portable routine', icon: 'wind', points: ['Use the AeroPress Go standard recipe', 'Keep the process simple on purpose', 'Good coffee beats travel coffee theatrics'], badge: 'Least fuss' },
        ]}
        outcome="You stop chasing random internet recipes and start using the method that actually matches your taste and routine"
