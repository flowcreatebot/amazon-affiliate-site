      <h3>5) 1:15 final cup on the MiiCoffee Nano scale — best bypass ratio for larger mugs</h3>
      <ProductCard
        title={products[4].name}
        asin={products[4].asin}
        image={{ src: products[4].image, alt: products[4].imageAlt, width: 500, height: 500 }}
        badge={products[4].badge}
