const amazonUrl = (asin: string) => `https://www.amazon.com/dp/${asin}/ref=nosim?tag=coffee-site-20`;

const title = 'Best Espresso Machine Under $200 (2026): 7 Picks Researched';
const description = 'Compare 7 researched espresso machines under $200 by machine type, basket style, milk system, heat-up time, and cleanup effort to buy the right budget model.';
const slug = 'best-espresso-machine-under-200';
const canonical = `${SITE.url}/posts/${slug}.html`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    blogPosting({
      headline: title,
      description: 'Compare 7 researched espresso machines under $200 by workflow fit, milk system quality, cleanup burden, and value.',
      slug,
      datePublished: '2026-03-06',
      dateModified: '2026-03-09',
      image: 'https://m.media-amazon.com/images/I/81c3ItE+jyL._AC_SL500_.jpg',
