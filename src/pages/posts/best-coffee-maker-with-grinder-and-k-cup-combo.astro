const canonical = `${SITE.url}/posts/${slug}.html`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    blogPosting({
      headline: 'Best Coffee Maker with Grinder and K-Cup Combo (2026): 7 Researched Picks',
