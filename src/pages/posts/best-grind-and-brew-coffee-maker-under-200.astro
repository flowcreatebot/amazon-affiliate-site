      ]
    },
    {
      "@type": "Organization",
      ...publisher,
      "url": SITE.url
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best grind-and-brew coffee maker under $200 right now?",
          "acceptedAnswer": {"@type": "Answer", "text": "For most buyers, Cuisinart DGB-550BKP1 is the strongest all-around pick under $200 because it balances value, programmable convenience, and manageable cleaning."}
        },
        {
          "@type": "Question",
          "name": "Are grind-and-brew machines under $200 worth it vs separate grinder + brewer?",
          "acceptedAnswer": {"@type": "Answer", "text": "Usually yes for convenience-first households. If flavor consistency is your top priority, a separate budget burr grinder plus drip brewer can outperform many integrated blade systems at similar total spend."}
        },
        {
          "@type": "Question",
          "name": "Can these machines brew pre-ground coffee too, or only whole beans?",
          "acceptedAnswer": {"@type": "Answer", "text": "Many under-$200 models support both beans and pre-ground coffee. Verify this mode explicitly in product specs before buying."}
        },
        {
          "@type": "Question",
          "name": "Do any models under $200 use burr grinders, or mostly blade grinders?",
          "acceptedAnswer": {"@type": "Answer", "text": "Most options in this range are blade-based, but a few models near the upper budget tier use burr systems and usually deliver better consistency."}
        },
        {
          "@type": "Question",
          "name": "How often do I need to clean the grinder chute/hopper to avoid stale flavor or clogs?",
          "acceptedAnswer": {"@type": "Answer", "text": "Brush grinder paths every 2-3 brews, rinse removable brew parts daily, and deep-clean weekly to reduce stale oils and clog risk."}
        },
        {
          "@type": "Question",
          "name": "What is a realistic bean-to-cup brew time on busy mornings?",
          "acceptedAnswer": {"@type": "Answer", "text": "Expect roughly 3.5-6 minutes for a small serving and up to 13 minutes for full-carafe batches depending on machine power and grind cycle length."}
        }
      ]
    },
  ],
};
