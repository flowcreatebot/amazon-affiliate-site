import HeroMedia from '../../components/HeroMedia.astro';
import Toc from '../../components/Toc.astro';
import { SITE, blogPosting, publisher } from '../../data/site';

const title = 'Best Grind and Brew Coffee Maker Under $200 (2026) Compared';
const description = 'Compare 7 researched grind-and-brew coffee makers under $200 by workflow speed, cleanup effort, brew flexibility, and practical day-to-day value.';
const slug = 'best-grind-and-brew-coffee-maker-under-200';
const canonical = `${SITE.url}/posts/${slug}.html`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    blogPosting({
      headline: 'Best Grind and Brew Coffee Maker Under $200 (2026): 7 Top Picks',
      description: '7 researched grind-and-brew coffee makers under $200 ranked by bean-to-cup speed, cleaning burden, compatibility, and practical value.',
      slug,
      datePublished: '2026-03-06',
      dateModified: '2026-03-06',
      image: `${SITE.url}/assets/images/best-grind-and-brew-coffee-maker-under-200-tested-2026.svg`,
    }),
    {
      "@type": "ItemList",
      "name": "Best Grind and Brew Coffee Maker Under $200 Picks",
      "itemListOrder": "https://schema.org/ItemListOrderAscending",
      "numberOfItems": 7,
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Cuisinart DGB-550BKP1"},
        {"@type":"ListItem","position":2,"name":"BLACK+DECKER 12-Cup Mill & Brew"},
        {"@type":"ListItem","position":3,"name":"Cuisinart DGB-400 Automatic Grind & Brew"},
