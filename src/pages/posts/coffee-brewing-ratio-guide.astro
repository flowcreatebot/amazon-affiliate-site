---
import HowToGuide from '../../layouts/page-types/HowToGuide.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
---

<HowToGuide
  slug="coffee-brewing-ratio-guide"
  title="Coffee Brewing Ratio Guide (Pour Over, French Press, AeroPress)"
  description="Simple coffee-to-water ratio cheat sheet for pour over, French press, and AeroPress. Includes quick adjustments for stronger or lighter cups."
  category="brewing"
  datePublished="2026-03-05"
  dateModified="2026-03-06"
  heroSteps={{
    title: "Better Coffee in 3 Steps",
    subtitle: "Start with these ratios, then adjust one variable at a time",
    steps: [
      { label: "Weigh", icon: "target", actions: ["Use a scale, not scoops", "Start at the ratio below", "Measure water by weight", "Keep dose consistent"], time: "30 sec" },
      { label: "Brew", icon: "coffee", actions: ["Pour over: 1:16", "French press: 1:15", "AeroPress: 1:14", "Adjust strength to taste"], time: "3-5 min" },
      { label: "Adjust", icon: "wrench", actions: ["Sour: grind finer", "Bitter: grind coarser", "Change one variable only", "Log what works"], time: "Ongoing" },
    ],
    outcome: "Consistent, repeatable cups without guesswork.",
    footer: "coffeegearlab.com - ratio guide - 2026",
  }}
  tocItems={[
    { href: '#quick-answer', label: 'Quick answer' },
    { href: '#ratio-chart', label: 'Quick ratio chart' },
    { href: '#example-calculation', label: 'Example calculation' },
    { href: '#troubleshooting', label: 'Fast troubleshooting' },
    { href: '#faq', label: 'Frequently asked questions' },
  ]}
  faqItems={[
    { q: 'What is a good starting coffee-to-water ratio?', a: 'For pour over start at 1:16, for French press 1:15, and for AeroPress 1:14. Adjust one step stronger or lighter based on taste.' },
    { q: 'Do I need a scale to use these ratios?', a: 'A scale gives the most consistent results. Scoops vary in density and grind size, so weighing both coffee and water removes guesswork.' },
    { q: 'How do I fix sour or bitter cups?', a: 'Sour and thin usually means grind finer or increase brew time slightly. Bitter and harsh usually means grind coarser or reduce brew time.' },
  ]}
  schemaSteps={[
    { name: 'Weigh coffee and water', text: 'Use a scale to measure coffee dose and water weight at the target ratio for your brew method.' },
    { name: 'Brew at the starting ratio', text: 'Pour over at 1:16, French press at 1:15, AeroPress at 1:14. Keep brew time consistent.' },
    { name: 'Adjust by taste', text: 'If sour, grind finer. If bitter, grind coarser. Change one variable at a time and log what works.' },
  ]}
  supplies={['Fresh coffee beans', 'Digital coffee scale', 'Filtered water']}
  schemaTools={['Pour over dripper', 'French press', 'AeroPress']}
>
  <Fragment slot="lead">
    <p class="lead">Use this quick chart to dial better cups faster. Start here, then adjust one variable at a time.</p>
  </Fragment>

  <Fragment slot="quick-answer">
    <h2 id="quick-answer">Quick answer</h2>
    <p>For pour over, start at <strong>1:16</strong>. For French press, start at <strong>1:15</strong>. For AeroPress, start at <strong>1:14</strong>. Adjust one step stronger or lighter based on taste. Always weigh both coffee and water for repeatable results.</p>
  </Fragment>

  <Fragment slot="steps">
    <h2 id="ratio-chart">Quick ratio chart</h2>
    <ComparisonTable>
      <table>
        <thead><tr><th>Method</th><th>Starting ratio</th><th>For stronger cup</th><th>For lighter cup</th></tr></thead>
        <tbody>
          <tr><td>Pour over</td><td data-label="Starting ratio">1:16</td><td data-label="For stronger cup">1:15</td><td data-label="For lighter cup">1:17</td></tr>
          <tr><td>French press</td><td data-label="Starting ratio">1:15</td><td data-label="For stronger cup">1:14</td><td data-label="For lighter cup">1:16</td></tr>
          <tr><td>AeroPress</td><td data-label="Starting ratio">1:14</td><td data-label="For stronger cup">1:13</td><td data-label="For lighter cup">1:15</td></tr>
        </tbody>
      </table>
    </ComparisonTable>

    <h2 id="example-calculation">Example calculation</h2>
    <p>For a 300 ml pour over at 1:16, use about <strong>19 g coffee</strong> (300 ÷ 16 = 18.75).</p>
  </Fragment>

  <Fragment slot="troubleshooting">
    <h2 id="troubleshooting">Fast troubleshooting</h2>
    <ul>
      <li><strong>Sour and thin:</strong> grind finer or increase brew time slightly.</li>
      <li><strong>Bitter and harsh:</strong> grind coarser or reduce brew time.</li>
      <li><strong>Flat flavor:</strong> use fresher beans and a better grinder.</li>
    </ul>
  </Fragment>

  <Fragment slot="extra-sections">
    <h2>Related guides</h2>
    <ul>
      <li><a href="/posts/best-single-serve-coffee-maker-with-grinder.html">Best Single-Serve Coffee Maker with Grinder</a></li>
      <li><a href="/posts/best-coffee-maker-with-grinder.html">Best Coffee Maker with Grinder</a></li>
      <li><a href="/posts/best-coffee-grinder-for-pour-over.html">Best Coffee Grinder for Pour Over</a></li>
      <li><a href="/posts/best-coffee-scale-for-espresso-and-pour-over.html">Best Coffee Scale for Espresso &amp; Pour Over</a></li>
      <li><a href="/posts/best-gooseneck-kettle-for-pour-over.html">Best Gooseneck Kettle for Pour Over</a></li>
      <li><a href="/posts/best-pour-over-coffee-maker.html">Best Pour Over Coffee Maker (2026)</a></li>
      <li><a href="/posts/aeropress-vs-french-press.html">AeroPress vs French Press</a></li>
      <li><a href="/posts/best-espresso-machine-under-200.html">Best Espresso Machine Under $200</a></li>
      <li><a href="/posts/best-manual-coffee-grinder-under-100.html">Best Manual Coffee Grinder Under $100</a></li>
    </ul>
  </Fragment>
</HowToGuide>
