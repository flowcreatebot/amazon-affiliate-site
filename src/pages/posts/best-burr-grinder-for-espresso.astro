    blogPosting({
      headline: title,
      description: 'Best burr grinders for espresso ranked by burr geometry, adjustment precision, retention behavior, and daily workflow fit.',
      slug,
      datePublished: '2026-03-06',
      dateModified: '2026-03-06',
