---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostListing from '../../components/PostListing.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { SITE } from '../../data/site';
import posts from '../../data/posts.json';

const title = `Coffee Buying Guides & Comparisons | ${SITE.name}`;
const description = `Browse all ${SITE.name} buying guides: budget espresso machines, burr grinders, coffee scales, brewer comparisons, and brew education posts.`;
const canonical = `${SITE.url}/posts/`;

const allPosts = [...posts].sort((a, b) => b.dateModified.localeCompare(a.dateModified));
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="website"
  ogUrl={canonical}
>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'All Coffee Guides' },
  ]} />

  <h1>All Coffee Buying Guides</h1>
  <p class="lead">High-intent buying pages and practical brew support content. Start with your next purchase, then use supporting guides to dial better cups.</p>

  <nav class="category-nav" aria-label="Browse by category">
    <a href="/espresso/">Espresso</a>
    <a href="/grinders/">Grinders</a>
    <a href="/brewers/">Brewers</a>
    <a href="/accessories/">Accessories</a>
    <a href="/education/">Education</a>
  </nav>

  <PostListing posts={allPosts} initialCount={10} showCategory={true} />

  <AffiliateDisclosure text="Some links may earn a commission at no extra cost to you. Recommendations focus on value-for-use-case, not payout." />
</BaseLayout>
