---
import ListingPage from '../../layouts/page-types/ListingPage.astro';
import { SITE } from '../../data/site';
import posts from '../../data/posts.json';

const allPosts = [...posts].sort((a, b) => b.dateModified.localeCompare(a.dateModified));

const categoryNav = [
  { label: 'Espresso', href: '/espresso/' },
  { label: 'Grinders', href: '/grinders/' },
  { label: 'Brewers', href: '/brewers/' },
  { label: 'Accessories', href: '/accessories/' },
  { label: 'Education', href: '/education/' },
];
---
<ListingPage
  title="All Coffee Buying Guides"
  seoTitle={`Coffee Buying Guides & Comparisons | ${SITE.name}`}
  description={`Browse all ${SITE.name} buying guides: budget espresso machines, burr grinders, coffee scales, brewer comparisons, and brew education posts.`}
  intro="High-intent buying pages and practical brew support content. Start with your next purchase, then use supporting guides to dial better cups."
  canonical={`${SITE.url}/posts/`}
  heroImage="/assets/hero-all-guides.webp"
  heroImageAlt="Curated flat lay of coffee gear including moka pots, grinders, scales, and kettles"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'All Coffee Guides' },
  ]}
  posts={allPosts}
  initialCount={10}
  showCategory={true}
  categoryNav={categoryNav}
/>
