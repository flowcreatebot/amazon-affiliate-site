    imageAlt: 'Fellow Prismo attachment with reusable metal filter for AeroPress brewers',
    category: 'accessories',
    rating: 4.6,
    specs: {
      packedWeight: 'About 2.1 oz',
      capacity: 'Depends on your brewer',
      brewStyle: 'No-drip immersion add-on',
      filterType: 'Reusable metal filter included',
      cleanupTime: 'Moderate',
      tradeoff: 'Makes richer cups and stops drip-through, but adds cleanup',
    },
    badge: { label: 'Best No-Drip Add-On', variant: 'upgrade' },
    price: 'Check price',
    bestFor: 'Anyone who loves AeroPress but hates coffee dripping early into the mug',
  },
  {
    id: 'stanley-boil-brew-backpacking',
    name: 'STANLEY Adventure All-in-One Boil + Brew French Press',
