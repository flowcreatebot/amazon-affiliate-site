    },
    badge: { label: 'Best Budget Pick', variant: 'budget' },
    price: 'Check price',
    bestFor: 'Backpackers who want AeroPress flavor without paying for the travel mug kit',
  },
  {
    id: 'gsi-ultralight-java-drip-backpacking',
    name: 'GSI Outdoors Ultralight Java Drip',
    brand: 'GSI Outdoors',
    asin: 'B001LF3ICU',
    image: 'https://m.media-amazon.com/images/I/71TqNlUO0KL._AC_SL500_.jpg',
