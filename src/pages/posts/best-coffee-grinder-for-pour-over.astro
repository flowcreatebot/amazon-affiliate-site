    blogPosting({
      headline: title,
      description: '7 researched pour-over grinder picks ranked by clarity, fines risk, retention/static behavior, and daily workflow fit.',
      slug,
      datePublished: '2026-03-05',
      dateModified: '2026-03-06',
      image: `${SITE.url}/assets/images/best-coffee-grinder-for-pour-over-tested-2026.svg`,
    }),
