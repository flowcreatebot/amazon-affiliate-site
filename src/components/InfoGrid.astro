---
interface Props {
  items: Array<{
    icon: string;
    title: string;
    description: string;
  }>;
  columns?: 2 | 3;
}
const { items, columns = 3 } = Astro.props;
---
<div class={`info-grid --cols-${columns}`}>
  {items.map(item => (
    <div class="info-grid__card">
      <span class="info-grid__icon">{item.icon}</span>
      <h3 class="info-grid__title">{item.title}</h3>
      <p class="info-grid__description">{item.description}</p>
    </div>
  ))}
</div>
