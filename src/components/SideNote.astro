---
/**
 * SideNote — an aside for definitions, tangential info, or editorial commentary.
 * Visually distinct from the main flow without being as heavy as a Callout.
 */
interface Props {
  label?: string;
}
const { label = 'Note' } = Astro.props;
---
<aside class="side-note">
  <span class="side-note__label">{label}</span>
  <div class="side-note__content">
    <slot />
  </div>
</aside>
