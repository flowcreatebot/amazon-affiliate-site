---
/**
 * SummaryBox — a conclusion or TL;DR box at the end of a section or article.
 * Different from KeyTakeaways which appears near the top.
 */
interface Props {
  title?: string;
}
const { title = 'The Bottom Line' } = Astro.props;
---
<div class="summary-box">
  <h3 class="summary-box__title">{title}</h3>
  <div class="summary-box__content">
    <slot />
  </div>
</div>
