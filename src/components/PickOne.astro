---
import CtaButton from './CtaButton.astro';

interface Option {
  label: string;
  icon: string;
  points: string[];
  badge?: string;
}

interface Props {
  title: string;
  subtitle: string;
  options: Option[];
  outcome: string;
}

const { title, subtitle, options, outcome } = Astro.props;

const optionCount = Math.min(options.length, 4);

const stepColors = ['#059669', '#0369A1', '#5C3D2E', '#7A5B4A'];

const icons: Record<string, string> = {
  timer: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="14" y1="2" y2="2"/><line x1="12" x2="15" y1="14" y2="11"/><circle cx="12" cy="14" r="8"/></svg>',
  zap: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>',
  wind: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>',
  wrench: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  droplets: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>',
  check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>',
  calendar: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>',
  coffee: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/><path d="M6 2v2"/></svg>',
  target: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
  list: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>',
};
---

<div class="pick-one">
  <div class="pick-one__header">
    <h2 class="pick-one__title">{title}</h2>
    <p class="pick-one__subtitle">{subtitle}</p>
  </div>
  <div class="pick-one__grid" style={`--option-count: ${optionCount}`}>
    {options.map((opt, i) => (
      <div class="pick-one-card" style={`--card-color: ${stepColors[i % stepColors.length]}`}>
        <div class="pick-one-card__head">
          <span class="pick-one-card__icon" set:html={icons[opt.icon]} />
          <span class="pick-one-card__label">{opt.label}</span>
        </div>
        <div class="pick-one-card__body">
          <ul class="pick-one-card__points">
            {opt.points.map((p) => <li>{p}</li>)}
          </ul>
          {opt.badge && (
            <span class="pick-one-card__badge" style={`--badge-color: ${stepColors[i % stepColors.length]}`}>
              {opt.badge}
            </span>
          )}
        </div>
      </div>
    ))}
  </div>
  <div class="pick-one__outcome">
    <span class="pick-one__outcome-label">Outcome</span>
    <p class="pick-one__outcome-text">{outcome}</p>
  </div>
</div>

<style>
  .pick-one {
    background: var(--surface-latte);
    border-radius: var(--radius);
    padding: 2rem 1.5rem 1.5rem;
    margin: var(--sp-5) 0 var(--sp-6);
  }
  @media (min-width: 960px) {
    .pick-one {
      width: min(var(--max-page), calc(100vw - 2rem));
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 2.5rem 2rem 1.5rem;
    }
  }

  .pick-one__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .pick-one__title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--brand-900);
    margin: 0 0 0.35rem;
  }
  .pick-one__subtitle {
    font-size: 1rem;
    color: var(--brand-700);
    margin: 0;
  }

  .pick-one__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) {
    .pick-one__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .pick-one__grid {
      grid-template-columns: repeat(var(--option-count, 3), 1fr);
      justify-items: center;
    }
  }

  .pick-one-card {
    background: var(--surface-elevated);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .pick-one-card__head {
    background: var(--card-color);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .pick-one-card__icon {
    display: block;
    width: 28px;
    height: 28px;
    color: #fff;
  }
  .pick-one-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .pick-one-card__label {
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pick-one-card__body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pick-one-card__points {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .pick-one-card__points li {
    font-size: 0.88rem;
    color: var(--brand-700);
  }
  .pick-one-card__points li::before {
    content: '\2713\00a0\00a0';
    color: var(--card-color);
    font-weight: 700;
  }

  .pick-one-card__badge {
    display: inline-block;
    align-self: center;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--badge-color);
    background: var(--surface-warm);
    border: 1.5px solid var(--badge-color);
    border-radius: var(--radius-pill);
    padding: 0.3rem 0.75rem;
    margin-top: 0.75rem;
  }

  .pick-one__outcome {
    background: var(--surface-warm);
    border: 1.5px solid var(--brand-400);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    text-align: center;
    margin-top: 1rem;
  }
  .pick-one__outcome-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand-600);
    margin-bottom: 0.2rem;
  }
  .pick-one__outcome-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--brand-900);
    margin: 0;
    line-height: 1.4;
  }
</style>
