---
interface Props {
  value: string;
  label: string;
  source?: string;
  variant?: 'inline' | 'featured';
}
const { value, label, source, variant = 'inline' } = Astro.props;
---
<div class={`data-card ${variant === 'featured' ? '--featured' : ''}`}>
  <span class="data-card__value">{value}</span>
  <span class="data-card__label">{label}</span>
  {source && <cite class="data-card__source">{source}</cite>}
</div>
