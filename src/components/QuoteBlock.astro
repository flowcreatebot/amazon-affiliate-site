---
interface Props {
  quote: string;
  author: string;
  role?: string;
}
const { quote, author, role } = Astro.props;
---
<blockquote class="quote-block">
  <p class="quote-block__text">"{quote}"</p>
  <p class="quote-block__attribution">
    — <span class="quote-block__author">{author}</span>{role && `, ${role}`}
  </p>
</blockquote>
