---
/**
 * NumberedInsight — editorial "big number + insight" cards.
 * For "5 things we learned" or "3 key takeaways from the data" style content.
 */
interface Props {
  items: Array<{
    title: string;
    description: string;
  }>;
}
const { items } = Astro.props;
---
<div class="numbered-insight">
  {items.map((item, i) => (
    <div class="numbered-insight__item">
      <span class="numbered-insight__number">{i + 1}</span>
      <div class="numbered-insight__body">
        <h3 class="numbered-insight__title">{item.title}</h3>
        <p class="numbered-insight__description">{item.description}</p>
      </div>
    </div>
  ))}
</div>
