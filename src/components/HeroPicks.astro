---
interface Pick {
  category: string;
  tagline: string;
  icon: string;
  features: string[];
  topPick: string;
  price: string;
  subtitle: string;
  asin: string;
  color: string;
}
interface Props {
  title: string;
  subtitle: string;
  picks: Pick[];
  footer?: string;
}
const { title, subtitle, picks, footer } = Astro.props;
const amazonUrl = (asin: string) => `https://www.amazon.com/dp/${asin}/ref=nosim?tag=coffee-site-20`;

const icons: Record<string, string> = {
  dollar: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  target: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
  'volume-x': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"/><line x1="22" x2="16" y1="9" y2="15"/><line x1="16" x2="22" y1="9" y2="15"/></svg>',
  hand: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>',
};
---

<div class="hero-picks">
  <div class="hero-picks__header">
    <h2 class="hero-picks__title">{title}</h2>
    <p class="hero-picks__subtitle">{subtitle}</p>
  </div>
  <div class="hero-picks__grid">
    {picks.map((pick) => (
      <div class="hero-pick-card" style={`--card-color: ${pick.color}`}>
        <div class="hero-pick-card__head">
          <span class="hero-pick-card__icon" set:html={icons[pick.icon]} />
          <span class="hero-pick-card__category">{pick.category}</span>
        </div>
        <div class="hero-pick-card__body">
          <p class="hero-pick-card__tagline">{pick.tagline}</p>
          <ul class="hero-pick-card__features">
            {pick.features.map((f) => <li>{f}</li>)}
          </ul>
          <div class="hero-pick-card__pick">
            <span class="hero-pick-card__pick-label">Top Pick</span>
            <span class="hero-pick-card__pick-name">{pick.topPick}</span>
          </div>
          <p class="hero-pick-card__price">{pick.price}</p>
          <p class="hero-pick-card__sub">{pick.subtitle}</p>
          <a href={amazonUrl(pick.asin)} class="hero-pick-card__cta" target="_blank" rel="nofollow noopener noreferrer sponsored">Check Price on Amazon</a>
        </div>
      </div>
    ))}
  </div>
  {footer && <p class="hero-picks__footer">{footer}</p>}
</div>

<style>
  .hero-picks {
    background: var(--surface-latte);
    border-radius: var(--radius);
    padding: 2rem 1.5rem 1.5rem;
    margin: var(--sp-5) 0 var(--sp-6);
  }
  @media (min-width: 960px) {
    .hero-picks {
      width: min(var(--max-page), calc(100vw - 2rem));
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 2.5rem 2rem 1.5rem;
    }
  }
  .hero-picks__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .hero-picks__title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--brand-900);
    margin: 0 0 0.35rem;
  }
  .hero-picks__subtitle {
    font-size: 1rem;
    color: var(--brand-700);
    margin: 0;
  }
  .hero-picks__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) {
    .hero-picks__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .hero-picks__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .hero-pick-card {
    background: var(--surface-elevated);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .hero-pick-card__head {
    background: var(--card-color);
    padding: 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .hero-pick-card__icon {
    display: block;
    width: 32px;
    height: 32px;
    color: #fff;
  }
  .hero-pick-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .hero-pick-card__category {
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .hero-pick-card__body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .hero-pick-card__tagline {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-900);
    text-align: center;
    margin: 0 0 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--brand-400);
  }
  .hero-pick-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .hero-pick-card__features li {
    font-size: 0.88rem;
    color: var(--brand-700);
  }
  .hero-pick-card__features li::before {
    content: '\2713\00a0\00a0';
    color: var(--cta);
    font-weight: 700;
  }
  .hero-pick-card__pick {
    background: var(--surface-warm);
    border: 1.5px solid var(--card-color);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.6rem;
    text-align: center;
    margin-top: 1rem;
  }
  .hero-pick-card__pick-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--card-color);
    margin-bottom: 0.15rem;
  }
  .hero-pick-card__pick-name {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--brand-900);
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-pick-card__price {
    text-align: center;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--brand-600);
    margin: 0.6rem 0 0.1rem;
  }
  .hero-pick-card__sub {
    text-align: center;
    font-size: 0.78rem;
    color: var(--brand-400);
    margin: 0 0 0.7rem;
  }
  .hero-pick-card__cta {
    display: block;
    text-align: center;
    background: var(--cta);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.6rem 0.5rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.15s;
  }
  .hero-pick-card__cta:hover {
    background: var(--cta-hover);
  }
  .hero-picks__footer {
    text-align: center;
    font-size: 0.82rem;
    color: var(--brand-400);
    margin: 1.25rem 0 0;
  }
</style>
