---
import CtaButton from './CtaButton.astro';
import { amazonUrl } from '../data/products';

interface NeedItem {
  name: string;
  desc: string;
  asin: string;
}

interface Props {
  items: NeedItem[];
}

const { items } = Astro.props;
---
<section class="what-youll-need">
  <h2 id="what-you-need">What you'll need</h2>
  <slot name="intro" />
  <ul class="what-youll-need__list">
    {items.map((item) => (
      <li class="what-youll-need__item">
        <div class="what-youll-need__info">
          <strong class="what-youll-need__name">{item.name}</strong>
          <span class="what-youll-need__desc">{item.desc}</span>
        </div>
        <div class="what-youll-need__action">
          <CtaButton href={amazonUrl(item.asin)} size="sm" external>Check price</CtaButton>
        </div>
      </li>
    ))}
  </ul>
  <slot />
</section>

<style>
  .what-youll-need {
    background: var(--surface-latte);
    border-left: 4px solid var(--brand-700);
    border-radius: var(--radius);
    padding: var(--sp-6);
    margin: var(--sp-8) 0;
  }

  .what-youll-need h2 {
    margin-top: 0;
  }

  .what-youll-need__list {
    list-style: none;
    padding: 0;
    margin: var(--sp-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .what-youll-need__item {
    background: var(--surface-white);
    border: 1px solid var(--brand-200);
    border-radius: var(--radius-sm);
    padding: var(--sp-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .what-youll-need__info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }

  .what-youll-need__name {
    font-size: 1.05rem;
    color: var(--brand-900);
  }

  .what-youll-need__desc {
    font-size: 0.9rem;
    color: var(--brand-600);
    line-height: 1.45;
  }

  .what-youll-need__action {
    flex-shrink: 0;
  }

  @media (max-width: 639px) {
    .what-youll-need {
      padding: var(--sp-4);
    }

    .what-youll-need__item {
      flex-direction: column;
      align-items: stretch;
      gap: var(--sp-3);
    }

    .what-youll-need__action {
      display: flex;
    }

    .what-youll-need__action :global(.cta-button) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
