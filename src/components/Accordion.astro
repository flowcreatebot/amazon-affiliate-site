---
/**
 * General-purpose accordion — for expandable content sections.
 * Different from FaqAccordion which is specifically for FAQ schema.
 */
interface Props {
  items: Array<{
    title: string;
    content: string;
  }>;
  title?: string;
}
const { items, title } = Astro.props;
---
<div class="accordion">
  {title && <h3 class="accordion__title">{title}</h3>}
  {items.map(item => (
    <details class="accordion__item">
      <summary class="accordion__summary">{item.title}</summary>
      <div class="accordion__content">
        <p>{item.content}</p>
      </div>
    </details>
  ))}
</div>
