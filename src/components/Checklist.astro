---
interface Props {
  title?: string;
  items: (string | { text: string })[];
}

const { title, items } = Astro.props;
const getText = (item: string | { text: string }) => typeof item === 'string' ? item : item.text;
---

<div class="checklist">
  {title && <h3 class="checklist__title">{title}</h3>}
  <ul class="checklist__list">
    {items.map((item) => (
      <li class="checklist__item">
        <svg class="checklist__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
        <span>{getText(item)}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .checklist {
    background: var(--surface-latte);
    border-radius: var(--radius);
    padding: var(--sp-6);
    margin: var(--sp-6) 0;
  }

  .checklist__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-900);
    margin: 0 0 var(--sp-4);
  }

  .checklist__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .checklist__item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: 0.95rem;
    color: var(--brand-700);
    line-height: 1.5;
  }

  .checklist__icon {
    flex-shrink: 0;
    color: var(--cta);
    margin-top: 0.1rem;
  }
</style>
