---
interface Props {
  posts: Array<{
    title: string;
    slug: string;
    category: string;
    excerpt?: string;
  }>;
  title?: string;
}
const { posts, title = 'Related Posts' } = Astro.props;
---
{posts.length > 0 && (
  <section class="related-posts">
    <h3>{title}</h3>
    <div class="related-posts__grid">
      {posts.map(post => (
        <a class="related-posts__card" href={`/posts/${post.slug}/`}>
          <div class="related-posts__card-category">{post.category}</div>
          <h4 class="related-posts__card-title">{post.title}</h4>
          {post.excerpt && <p class="related-posts__card-excerpt">{post.excerpt}</p>}
        </a>
      ))}
    </div>
  </section>
)}
