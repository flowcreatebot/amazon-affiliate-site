---
interface Props {
  text: string;
  href?: string;
}
const { text, href } = Astro.props;

const PUBLIC_TAGS = new Set([
  "Budget Espresso",
  "Brewer Comparison",
  "Espresso Workflow",
  "Hybrid Bean + Pod",
]);

const isPublic = PUBLIC_TAGS.has(text);
---
{isPublic && (
  href ? (
    <a href={href} class="pill">{text}</a>
  ) : (
    <span class="pill">{text}</span>
  )
)}
