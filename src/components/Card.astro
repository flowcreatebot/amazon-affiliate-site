---
interface Props {
  title: string;
  href: string;
  class?: string;
  hidden?: boolean;
}
const { title, href, class: extraClass, hidden } = Astro.props;
const classes = ['card', extraClass].filter(Boolean).join(' ');
---
<article class={classes} style={hidden ? 'display:none' : ''}>
  <h3><a href={href}>{title}</a></h3>
  <slot />
</article>
