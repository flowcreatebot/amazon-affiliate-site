---
/**
 * HeroListicle — editorial listicle header with count and key insight.
 * For "7 Lessons From..." or "5 Things Every Marketer Should Know" style articles.
 */
interface Props {
  count: number;
  title: string;
  subtitle?: string;
  takeaway?: string;
}
const { count, title, subtitle, takeaway } = Astro.props;
---
<div class="hero-listicle">
  <div class="hero-listicle__count">{count}</div>
  <h2 class="hero-listicle__title">{title}</h2>
  {subtitle && <p class="hero-listicle__subtitle">{subtitle}</p>}
  {takeaway && <div class="hero-listicle__takeaway">{takeaway}</div>}
</div>
