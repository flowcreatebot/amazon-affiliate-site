---
/**
 * HowToPage template — step-by-step process guide
 *
 * Auto-renders: BlogLayout, H1, HeroSteps, Toc, FaqAccordion, AuthorBio, JSON-LD (HowTo)
 * Writer fills: lead, prerequisites, steps, tips, extra-sections
 */
import BlogLayout from '../BlogLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import HeroSteps from '../../components/HeroSteps.astro';
import Toc from '../../components/Toc.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqItem from '../../components/FaqItem.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { SITE, AUTHOR } from '../../data/site';
import { howToSchema } from '../../data/schema';
import type { TocItem, FaqItem as FaqItemType, HeroStepsConfig, BasePageProps } from './types';

interface HowToStep {
  name: string;
  text: string;
}

interface Props extends BasePageProps {
  heroSteps: HeroStepsConfig;
  tocItems: TocItem[];
  faqItems?: FaqItemType[];
  schemaSteps: HowToStep[];
  supplies?: string[];
  schemaTools?: string[];
}

const {
  slug, title, description, category,
  datePublished, dateModified, ogImage, ogDescription,
  heroSteps, tocItems, faqItems,
  schemaSteps, supplies, schemaTools,
} = Astro.props;

const canonical = `${SITE.url}/posts/${slug}/`;

const jsonLd = howToSchema({
  title, description, slug, datePublished, dateModified,
  image: ogImage,
  siteUrl: SITE.url, authorName: AUTHOR.name,
  howToName: title,
  howToDescription: description,
  steps: schemaSteps,
  supplies, tools: schemaTools,
});
---

<BlogLayout
  title={title}
  description={description}
  canonical={canonical}
  ogDescription={ogDescription}
  ogImage={ogImage}
  slug={slug}
  category={category}
  datePublished={datePublished}
  dateModified={dateModified}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'All Posts', href: '/posts/' },
    { label: title },
  ]}
>
  <Fragment slot="head">
    <JsonLd data={jsonLd} />
  </Fragment>

  <h1>{title}</h1>
  <slot name="lead" />

  <HeroSteps
    title={heroSteps.title}
    subtitle={heroSteps.subtitle}
    steps={heroSteps.steps}
    outcome={heroSteps.outcome}
  />

  <Toc items={tocItems} />

  <slot name="prerequisites" />

  <slot name="steps" />

  <slot name="tips" />

  <slot name="extra-sections" />

  {faqItems && faqItems.length > 0 && (
    <section>
      <h2 id="faq">Frequently Asked Questions</h2>
      <FaqAccordion>
        {faqItems.map((item) => (
          <FaqItem question={item.q}>
            <p>{item.a}</p>
          </FaqItem>
        ))}
      </FaqAccordion>
    </section>
  )}

  <AuthorBio />
</BlogLayout>
