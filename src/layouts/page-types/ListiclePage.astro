---
/**
 * ListiclePage template — numbered items (tips, tools, mistakes)
 *
 * Auto-renders: BlogLayout, H1, HeroListicle, Toc, FaqAccordion, AuthorBio
 * Writer fills: lead, items, methodology, extra-sections
 */
import BlogLayout from '../BlogLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import HeroListicle from '../../components/HeroListicle.astro';
import Toc from '../../components/Toc.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqItem from '../../components/FaqItem.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { SITE, AUTHOR } from '../../data/site';
import { articleWithFaqSchema } from '../../data/schema';
import type { TocItem, FaqItem as FaqItemType, BasePageProps } from './types';

interface Props extends BasePageProps {
  listCount: number;
  heroSubtitle?: string;
  keyTakeaway?: string;
  tocItems: TocItem[];
  faqItems?: FaqItemType[];
}

const {
  slug, title, description, category,
  datePublished, dateModified, ogImage, ogDescription,
  listCount, heroSubtitle, keyTakeaway, tocItems, faqItems,
} = Astro.props;

const canonical = `${SITE.url}/posts/${slug}/`;

const jsonLd = articleWithFaqSchema({
  title, description, slug, datePublished, dateModified,
  image: ogImage,
  siteUrl: SITE.url, authorName: AUTHOR.name,
  faqItems,
});
---

<BlogLayout
  title={title}
  description={description}
  canonical={canonical}
  ogDescription={ogDescription}
  ogImage={ogImage}
  slug={slug}
  category={category}
  datePublished={datePublished}
  dateModified={dateModified}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'All Posts', href: '/posts/' },
    { label: title },
  ]}
>
  <Fragment slot="head">
    <JsonLd data={jsonLd} />
  </Fragment>

  <h1>{title}</h1>
  <slot name="lead" />

  <HeroListicle
    count={listCount}
    title={title}
    subtitle={heroSubtitle}
    takeaway={keyTakeaway}
  />

  <Toc items={tocItems} />

  <slot name="items" />

  <slot name="methodology" />

  <slot name="extra-sections" />

  {faqItems && faqItems.length > 0 && (
    <section>
      <h2 id="faq">Frequently Asked Questions</h2>
      <FaqAccordion>
        {faqItems.map((item) => (
          <FaqItem question={item.q}>
            <p>{item.a}</p>
          </FaqItem>
        ))}
      </FaqAccordion>
    </section>
  )}

  <AuthorBio />
</BlogLayout>
