---
/**
 * CaseStudyPage template — results-focused story with metrics
 *
 * Auto-renders: BlogLayout, H1, Toc, AuthorBio
 * Writer fills: lead, metrics, challenge, approach, results, testimonial, key-learnings, extra-sections
 */
import BlogLayout from '../BlogLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import Toc from '../../components/Toc.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { SITE, AUTHOR } from '../../data/site';
import { blogPostingSchema } from '../../data/schema';
import type { TocItem, BasePageProps } from './types';

interface Props extends BasePageProps {
  tocItems: TocItem[];
}

const {
  slug, title, description, category,
  datePublished, dateModified, ogImage, ogDescription,
  tocItems,
} = Astro.props;

const canonical = `${SITE.url}/posts/${slug}/`;

const jsonLd = blogPostingSchema({
  title, description, slug, datePublished, dateModified,
  image: ogImage,
  siteUrl: SITE.url, authorName: AUTHOR.name,
});
---

<BlogLayout
  title={title}
  description={description}
  canonical={canonical}
  ogDescription={ogDescription}
  ogImage={ogImage}
  slug={slug}
  category={category}
  datePublished={datePublished}
  dateModified={dateModified}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Case Studies', href: '/case-studies/' },
    { label: title },
  ]}
>
  <Fragment slot="head">
    <JsonLd data={jsonLd} />
  </Fragment>

  <h1>{title}</h1>
  <slot name="lead" />

  <slot name="metrics" />

  <Toc items={tocItems} />

  <slot name="challenge" />

  <slot name="approach" />

  <slot name="results" />

  <slot name="testimonial" />

  <slot name="key-learnings" />

  <slot name="extra-sections" />

  <AuthorBio />
</BlogLayout>
