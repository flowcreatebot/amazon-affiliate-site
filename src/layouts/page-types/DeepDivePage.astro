---
/**
 * DeepDivePage template — long-form analysis / thought leadership
 *
 * Auto-renders: BlogLayout, H1, HeroArticle, KeyTakeaways, Toc, FaqAccordion, AuthorBio
 * Writer fills: lead, thesis, analysis, implications, extra-sections
 */
import BlogLayout from '../BlogLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import HeroArticle from '../../components/HeroArticle.astro';
import KeyTakeaways from '../../components/KeyTakeaways.astro';
import Toc from '../../components/Toc.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqItem from '../../components/FaqItem.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { SITE, AUTHOR } from '../../data/site';
import { articleWithFaqSchema } from '../../data/schema';
import type { TocItem, FaqItem as FaqItemType, BasePageProps } from './types';

interface Props extends BasePageProps {
  heroImage?: { src: string; alt: string };
  tocItems: TocItem[];
  keyTakeaways?: string[];
  faqItems?: FaqItemType[];
}

const {
  slug, title, description, category,
  datePublished, dateModified, ogImage, ogDescription,
  heroImage, tocItems, keyTakeaways, faqItems,
} = Astro.props;

const canonical = `${SITE.url}/posts/${slug}/`;

const jsonLd = articleWithFaqSchema({
  title, description, slug, datePublished, dateModified,
  image: ogImage ?? heroImage?.src,
  siteUrl: SITE.url, authorName: AUTHOR.name,
  faqItems,
});
---

<BlogLayout
  title={title}
  description={description}
  canonical={canonical}
  ogDescription={ogDescription}
  ogImage={ogImage}
  slug={slug}
  category={category}
  datePublished={datePublished}
  dateModified={dateModified}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'All Posts', href: '/posts/' },
    { label: title },
  ]}
>
  <Fragment slot="head">
    <JsonLd data={jsonLd} />
  </Fragment>

  <h1>{title}</h1>
  <slot name="lead" />

  {heroImage && (
    <HeroArticle image={heroImage} category={category} />
  )}

  {keyTakeaways && keyTakeaways.length > 0 && (
    <KeyTakeaways items={keyTakeaways} />
  )}

  <Toc items={tocItems} />

  <slot name="thesis" />

  <slot name="analysis" />

  <slot name="implications" />

  <slot name="extra-sections" />

  {faqItems && faqItems.length > 0 && (
    <section>
      <h2 id="faq">Frequently Asked Questions</h2>
      <FaqAccordion>
        {faqItems.map((item) => (
          <FaqItem question={item.q}>
            <p>{item.a}</p>
          </FaqItem>
        ))}
      </FaqAccordion>
    </section>
  )}

  <AuthorBio />
</BlogLayout>
